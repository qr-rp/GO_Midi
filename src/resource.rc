#include <windows.h>

1 ICON "assets/icon.ico"
APP_ICON ICON "assets/icon.ico"

// Embed the application manifest for administrator privileges
// Manifest ID 1 is for the executable, 2 is for the installer
1 RT_MANIFEST "Win32.manifest"

// Prevent wxWidgets from embedding its own manifest (asInvoker),
// which would override our requireAdministrator setting.
#define wxUSE_NO_MANIFEST 1
#include <wx/msw/wx.rc>
